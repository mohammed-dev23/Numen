# Variables
set x = 10;
set y = 3;
fix max = 100;

# Arithmetic
print x + y;
print x - y;
print x * y;
print x / y;
print x // y;
print x % y;
print x ^ y;

# Strings & booleans
set name = "Numen";
print name;
print true;
print false;

# Comparisons
print x == y;
print x != y;
print x > y;
print x < y;

# Logical
set a = true;
set b = false;
print a and b;
print a or b;

# If / else
set score = 87;
if score >= 90 {
    print "A";
} else {
    print "B";
}
