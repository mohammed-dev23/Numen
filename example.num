# this is simple number negativety checker in numen

fix x = -1;
make y = 0;

if x < 0 {
    print "negative";
    y = 5;
}

# else statement will be added soon!
if x > 0 {
    print "positive";
    y = -5;
}

if y >= 0 and y != 4 or y != 3 or y != 2 or y != 1 {
    print "and it's not lower then your body temp";
}
